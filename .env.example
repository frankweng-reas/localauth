# Database
DATABASE_URL="postgresql://user:password@localhost:5432/localauth"

# JWT Configuration
JWT_SECRET=your-secret-key-here
# Access token 有效期（預設 1h），格式: 60s, 15m, 1h, 7d
JWT_ACCESS_EXPIRES_IN=1h
# Refresh token 有效期（預設 7d）
JWT_REFRESH_EXPIRES_IN=7d

# Application
PORT=4000
BASE_URL=http://localhost:4000

# AD Integration (optional)
AD_ENABLED=false
# AD_URL=ldap://ad.company.com
# AD_BASE_DN=DC=company,DC=com
# AD_BIND_DN=CN=service,OU=Users
# AD_BIND_PASSWORD=xxx

# Email Service
# 選項: 'resend' | 'sendgrid' | 'smtp' | 'console'
EMAIL_PROVIDER=console
# Resend API Key (從 https://resend.com 取得)
RESEND_API_KEY=re_your_api_key_here
# 寄件者 email
EMAIL_FROM=noreply@yourdomain.com
